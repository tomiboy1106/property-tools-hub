{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "builds": [
    {
      "src": "homepage/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "buyer-budget/**",
      "use": "@vercel/static"
    },
    {
      "src": "seller-net/**",
      "use": "@vercel/static"
    }
  ],
  "redirects": [
    {
      "source": "/buyer-budget",
      "destination": "/buyer-budget/",
      "permanent": true
    },
    {
      "source": "/seller-net",
      "destination": "/seller-net/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/buyer-budget/",
      "destination": "/buyer-budget/index.html"
    },
    {
      "source": "/seller-net/",
      "destination": "/seller-net/index.html"
    }
  ]
}
